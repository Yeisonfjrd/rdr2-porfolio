# Optional: Email service for contact form (if you integrate one)
# EMAILJS_SERVICE_ID=your_service_id
# EMAILJS_TEMPLATE_ID=your_template_id
# EMAILJS_PUBLIC_KEY=your_public_key

# Optional: Analytics (already set up with Vercel Analytics)
# NEXT_PUBLIC_VERCEL_ENV=production

# Optional: Contact form backend (uncomment if using external service)
# NEXT_PUBLIC_FORM_ENDPOINT=your_endpoint_url

# Note: This portfolio works without any environment variables!
# It's completely client-side and doesn't require external services.
